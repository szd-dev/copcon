# LiteLLM 环境变量配置模板
# 复制此文件为 .env 并填入你的 API Keys

# ==================== LiteLLM 核心配置 ====================
# 主密钥 - 用于访问 LiteLLM API
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# Salt 密钥 - 用于加密敏感数据
LITELLM_SALT_KEY=sk-litellm-salt-key-change-me

# Admin UI 登录凭据
UI_USERNAME=admin
UI_PASSWORD=admin123

# ==================== LLM Provider API Keys ====================

# Moonshot / Kimi (推荐 - 工具调用完全兼容)
# 获取地址: https://platform.moonshot.ai/
MOONSHOT_API_KEY=your-moonshot-api-key

# OpenAI
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key

# Anthropic Claude
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini
# 获取地址: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# DeepSeek
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# ==================== 可选配置 ====================

# 数据库 URL (用于持久化配置和日志)
# DATABASE_URL=postgresql://user:password@localhost:5432/litellm

# 日志详细程度
SET_VERBOSE=false