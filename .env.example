# 环境变量配置模板
# 复制此文件为 .env 并填入你的 API Keys

# ==================== LiteLLM 配置 ====================
# LiteLLM 主密钥 - 用于访问 LiteLLM API (也是 server 的 OPENAI_API_KEY)
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# LiteLLM Salt 密钥 - 用于加密敏感数据
LITELLM_SALT_KEY=sk-litellm-salt-key-change-me

# ==================== LLM Provider API Keys ====================
# Moonshot / Kimi (推荐 - 工具调用完全兼容)
MOONSHOT_API_KEY=your-moonshot-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
